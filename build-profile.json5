{
  "app": {
    "signingConfigs": [
      {
        "name": "debug",
        // 调试证书
        "type": "HarmonyOS",
        "material": {
          "storeFile": "",
          "storePassword": "",
          "keyAlias": "xiaobaigongfang",
          "keyPassword": "",
          "signAlg": "SHA256withECDSA",
          "profile": "",
          "certpath": ""
        }
      },
      {
        "name": "release",
        // 发布证书
        "type": "HarmonyOS",
        "material": {
          "storeFile": "",
          "storePassword": "",
          "keyAlias": "xiaobaigongfang",
          "keyPassword": "",
          "signAlg": "SHA256withECDSA",
          "profile": "",
          "certpath": ""
        }
      }
    ],
    // 产品配置
    "products": [
      {
        "name": "default",
        "signingConfig": "debug",
        "compatibleSdkVersion": "5.0.5(17)",
        "targetSdkVersion": "6.0.0(20)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          },
          "externalNativeOptions": {
            "abiFilters": [
              "arm64-v8a",
              "x86_64"
            ]
          }
        }
      },
      {
        "name": "release",
        "signingConfig": "release",
        "compatibleSdkVersion": "5.0.5(17)",
        "targetSdkVersion": "6.0.0(20)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          },
          "externalNativeOptions": {
            "abiFilters": [
              "arm64-v8a",
              "x86_64"
            ]
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug",
      },
      {
        "name": "release"
      }
    ]
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./entry",
      "targets": [
        {
          "name": "default",
          // 入口模块的产品信息配置
          "applyToProducts": [
            "default",
            "release"
          ]
        }
      ]
    },
    {
      "name": "proxy_core",
      "srcPath": "./proxy_core",
    },
    {
      "name": "xb_components",
      "srcPath": "./xb_components"
    }
  ]
}